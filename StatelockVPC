#statelock 
#$ cat backend.tf

terraform {
  backend "s3" {
    bucket         = "statelockdemo004"                   //S3 bucket name - create this manually in AWS
    key            = "dev/vpc/terraform.tfstate"          // path inside S3 bucket where state file is saved  // this dev vpc and tf will create automatically
    region         = "us-east-2"                          // AWS region where S3 bucket is created
    encrypt        = true                                 // encrypt state file at rest in S3
    dynamodb_table = "terraform-locks"                    // DynamoDB table name - create this manually in AWS  // dynamodb - tablename= terraform-locks and partition key = LockID
  }
}


#terraform force-unlock <LOCK_ID>

#Use terraform state list and terraform state show to verify the state before unlocking.

AWS Console → S3 → statelockdemo004 → Properties → Versioning → Enable

Then every apply auto saves a new version:

apply (1st) → state v1
apply (2nd) → state v2   (v1 still exists)
apply (3rd) → state v3   (v1, v2 still exist)


Copy the previous VersionId and download it:

aws s3api get-object \
  --bucket statelockdemo0045 \
  --key dev/vpc/terraform.tfstate \
  --version-id <PASTE_VERSION_ID_HERE> \
  previous.tfstate

