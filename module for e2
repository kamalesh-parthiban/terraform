Now calling it for dev and prod:

# just 6 lines each — instead of 12 resources × 2 = 24 resource blocks
module "dev_ec2" {
  source      = "./modules/ec2"
  name        = "dev-ec2"
  instance_type = "t2.micro"
  ami         = "ami-111"
  env         = "dev"
  ebs_size    = 20
  alert_email = "dev@myorg.com"
}

module "prod_ec2" {
  source      = "./modules/ec2"
  name        = "prod-ec2"
  instance_type = "t3.large"
  ami         = "ami-222"
  env         = "prod"
  ebs_size    = 100
  alert_email = "prod@myorg.com"
}

